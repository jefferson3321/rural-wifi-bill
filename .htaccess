DirectoryIndex index.php index.html

RewriteEngine On
RewriteRule ^customer$ /customer_login.php [L,R=301]
RewriteRule ^admin$ /admin_login.php [L,R=301]

# Protect sensitive files
<FilesMatch "\.(sql|env|json|toml|log)$">
    Require all denied
</FilesMatch>
<FilesMatch "^(admin_pass|reset_admin)\.php$">
    Require all denied
</FilesMatch>
<FilesMatch "^(admin|customer)\.html$">
    Require all denied
</FilesMatch>
Options -Indexes
ServerSignature Off
